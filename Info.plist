<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>com.zrottmann.bounties</string>
    <key>CFBundleName</key>
    <string>BountyHunter</string>
    <key>CFBundleDisplayName</key>
    <string>BountyHunter</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>
    <key>CFBundleVersion</key>
    <string>4</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>
    <key>NSPhotoLibraryUsageDescription</key>
    <string>BountyHunter needs access to your photos so you can attach a picture of the job and upload evidence when a step is complete.</string>
    <key>NSCameraUsageDescription</key>
    <string>BountyHunter uses your camera so you can take a photo of the job or capture evidence when completing a step.</string>
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>BountyHunter uses your location to show nearby jobs and sort the hunter feed by distance.</string>
    <key>ITSAppUsesNonExemptEncryption</key>
    <false/>
    <key>CFBundleIcons</key>
    <dict>
        <key>CFBundlePrimaryIcon</key>
        <dict>
            <key>CFBundleIconFiles</key>
            <array>
                <string>AppIcon</string>
            </array>
            <key>CFBundleIconName</key>
            <string>AppIcon</string>
        </dict>
    </dict>
</dict>
</plist>
